D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:185:/* ---- 4. Set up RSE backing store ----
D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:189:movl r14 = rse_backing_store_base ;;
D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:192:mov ar.rsc = 3 ;;       /* eager RSE mode, little-endian */
D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:197:movl r14 = ia64_ivt ;;
D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:216:* IA-64 C calling convention: first two args in out0, out1.
D:\dev\guideXOSServer\kernel\arch\ia64\boot.s:241:* RSE (Register Stack Engine) backing store � 64 KB (BSS)
