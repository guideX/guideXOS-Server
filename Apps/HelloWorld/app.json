{
  "schemaVersion": 1,
  "id": "com.guidexos.helloworld",
  "displayName": "Hello World",
  "version": "0.1.0",
  "publisher": "guideXOS",
  "description": "Manifest discovery fixture for a future external NativeElf app. The referenced ELF files are intentionally absent and execution is not implemented yet.",
  "category": "Diagnostics",
  "kind": "NativeElf",
  "icon": "resources/icon.png",
  "minGuideXOSVersion": "0.1.0",
  "supportedArchitectures": [
    "amd64",
    "x86",
    "arm64"
  ],
  "entries": [
    {
      "architecture": "amd64",
      "path": "bin/amd64/helloworld.elf",
      "entryPoint": "gx_main",
      "abi": "guidexos-c-abi-v1",
      "runtime": "native-elf"
    },
    {
      "architecture": "x86",
      "path": "bin/x86/helloworld.elf",
      "entryPoint": "gx_main",
      "abi": "guidexos-c-abi-v1",
      "runtime": "native-elf"
    },
    {
      "architecture": "arm64",
      "path": "bin/arm64/helloworld.elf",
      "entryPoint": "gx_main",
      "abi": "guidexos-c-abi-v1",
      "runtime": "native-elf"
    }
  ],
  "permissions": [
    "log",
    "window"
  ],
  "fileAssociations": [],
  "defaultWindow": {
    "width": 640,
    "height": 480,
    "resizable": true
  }
}
